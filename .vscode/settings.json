{
  "liveSassCompile.settings.formats": [
    {
      "format": "compressed",
      "extensionName": "-min.css",
      "savePath": "/styles",
      "generateMap": false
    }
  ],
  "liveSassCompile.settings.excludeList": [
    "/**/node_modules/**",
    "/.vscode/**",
    "/styles/base/**",
    "/styles/utils/**",
    "/styles/pages/**",
    "/styles/components/**",
  ]
}